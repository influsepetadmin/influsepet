# Copy to .env and fill with real values. Never commit .env to version control.

# -----------------------------------------------------------------------------
# Required for Prisma (PostgreSQL)
# -----------------------------------------------------------------------------
# Create the database first (e.g. createdb influsepet). Adjust user, password, host, port.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/influsepet?schema=public"

# -----------------------------------------------------------------------------
# Session cookies (HMAC signing)
# -----------------------------------------------------------------------------
# Production: REQUIRED — at least 32 random characters (e.g. openssl rand -base64 48).
# Development: optional; a dev fallback exists if unset (not for production).
SESSION_SECRET="replace-with-a-long-random-secret-at-least-32-characters"

# -----------------------------------------------------------------------------
# Public site URL (no trailing slash)
# -----------------------------------------------------------------------------
# Used for metadata, sitemap, canonical URLs. Local dev example:
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Production example (replace with your domain):
# NEXT_PUBLIC_SITE_URL="https://www.example.com"
#
# Note: NEXT_PUBLIC_* variables are inlined at build time — set them when running
#       `npm run build` for production.

# -----------------------------------------------------------------------------
# Profile image storage (Cloudflare R2)
# Production target values are documented below. For local fallback, leave all
# five variables empty, including R2_BUCKET and R2_PUBLIC_BASE_URL.
# -----------------------------------------------------------------------------
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=influsepet-profile-images
R2_PUBLIC_BASE_URL=https://media.influsepet.com

# -----------------------------------------------------------------------------
# Optional platform variables (usually do not add to .env manually)
# -----------------------------------------------------------------------------
# VERCEL_URL — set automatically on Vercel; used only as a fallback when NEXT_PUBLIC_SITE_URL is unset.
